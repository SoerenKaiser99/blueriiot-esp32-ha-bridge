# Copy this file to /config/esphome/secrets.yaml and fill in your values.
#
# Quoting strings is recommended (especially for passwords with special chars).

# WiFi
wifi_ssid: "YourWiFiSSID"
wifi_password: "YourWiFiPassword"

# Blueriiot Blue Connect Plus Salt
# blueriiot_mac:        MAC of your sensor (find with blueconnect-scan.yaml)
# blueriiot_nameprefix: Prefix used in entity names ("Pool", "Whirlpool", ...)
# blueriiot_idprefix:   lowercase prefix for internal IDs (must match nameprefix in lowercase)
blueriiot_mac: "00:A0:50:XX:XX:XX"
blueriiot_nameprefix: "Pool"
blueriiot_idprefix: "pool"

# Local web UI on the ESP32 itself (http://<ip>/, user: admin)
web_server_password: "ChooseAStrongPassword"
